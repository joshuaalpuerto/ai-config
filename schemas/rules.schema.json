{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rules.schema.json",
  "title": "Rule Source Frontmatter",
  "description": "Frontmatter schema for source files under src/rules/.",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {
    "description": { "type": "string" },
    "paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/RuleOverride" }
    }
  },
  "$defs": {
    "RuleOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "applyTo":     { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
