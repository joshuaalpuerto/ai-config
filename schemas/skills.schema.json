{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skills.schema.json",
  "title": "Skill Source Frontmatter",
  "description": "Frontmatter schema for source files under src/skills/.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": false,
  "properties": {
    "name":          { "type": "string" },
    "description":   { "type": "string" },
    "argument-hint": { "type": "string" },
    "allowed-tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/SkillOverride" }
    }
  },
  "$defs": {
    "SkillOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name":          { "type": "string" },
        "description":   { "type": "string" },
        "argument-hint": { "type": "string" },
        "allowed-tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
