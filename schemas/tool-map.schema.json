{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool-map.schema.json",
  "title": "Tool Map Configuration",
  "description": "Maps canonical Claude tool names to platform-specific equivalents. Omit a tool entry to drop it for that platform.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z][a-z0-9_-]*$": {
      "$ref": "#/$defs/PlatformToolMap"
    }
  },
  "$defs": {
    "PlatformToolMap": {
      "type": "object",
      "description": "Canonical tool name → platform-specific tool name. Omit a key to drop that tool for this platform.",
      "additionalProperties": false,
      "properties": {
        "Bash":       { "type": "string", "description": "Shell command execution." },
        "Read":       { "type": "string", "description": "File read." },
        "Write":      { "type": "string", "description": "File write." },
        "Edit":       { "type": "string", "description": "File edit/patch." },
        "Glob":       { "type": "string", "description": "File glob search." },
        "Grep":       { "type": "string", "description": "Content search." },
        "Agent":      { "type": "string", "description": "Sub-agent invocation." },
        "WebSearch":  { "type": "string", "description": "Web search." },
        "TaskCreate": { "type": "string", "description": "Create a task/todo." },
        "TaskGet":    { "type": "string", "description": "Get a task/todo." },
        "TaskList":   { "type": "string", "description": "List tasks/todos." },
        "TaskUpdate": { "type": "string", "description": "Update a task/todo." }
      }
    }
  }
}
