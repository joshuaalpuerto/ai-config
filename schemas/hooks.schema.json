{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hooks.schema.json",
  "title": "RuleZ Hooks Configuration",
  "description": "Policy rules evaluated by aicfg hooks on every AI action.",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "const": "1" },
    "PreToolUse": {
      "type": "array",
      "items": { "$ref": "#/$defs/Rule" }
    },
    "PostToolUse": {
      "type": "array",
      "items": { "$ref": "#/$defs/Rule" }
    },
    "settings": { "$ref": "#/$defs/Settings" }
  },
  "$defs": {
    "CanonicalTool": {
      "type": "string",
      "enum": ["Bash", "Read", "Write", "Edit", "WebFetch"]
    },
    "PolicyMode": {
      "type": "string",
      "enum": ["enforce", "warn", "audit"],
      "default": "enforce"
    },
    "Rule": {
      "type": "object",
      "required": ["match", "action"],
      "additionalProperties": false,
      "properties": {
        "mode":   { "$ref": "#/$defs/PolicyMode" },
        "match":  { "$ref": "#/$defs/Matchers" },
        "action": { "$ref": "#/$defs/Actions" }
      }
    },
    "Matchers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools":         { "type": "array", "items": { "$ref": "#/$defs/CanonicalTool" } },
        "command_match": { "type": "string", "description": "Regex matched against tool_input.command (Bash only)." },
        "paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns matched against the file path. Three forms are supported: (1) No path separator — e.g. '*.go' — matches the filename only, regardless of directory. (2) Trailing '/' — e.g. 'src/api/' — matches any file inside that directory. (3) Full path glob — e.g. 'src/**/*.ts' — matched against the full file path; '**' matches zero or more path segments."
        }
      }
    },
    "Actions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "block":         { "type": "boolean" },
        "message":       { "type": "string", "description": "Human-readable reason shown when a rule blocks." },
        "inject":        { "type": "string", "description": "Path relative to repo root (e.g. context/standards.md)." },
        "inject_inline": { "type": "string" },
        "run":           { "type": "string", "description": "Path to a validator script executed with the event JSON on stdin." }
      }
    },
    "Settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fail_open": { "type": "boolean", "default": true }
      }
    }
  }
}
